{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "#{DB_CONNECTION}#"
  },
  "Jwt": {
    "Issuer": "Plataforma2A.Auth",
    "Audience": "Plataforma2A.Auth",
    "Key": "#{JWT_SIGNING_KEY}#",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Smtp": {
    "Host": "#{SMTP_HOST}#",
    "Port": 587,
    "From": "#{SMTP_FROM}#",
    "Username": "#{SMTP_USERNAME}#",
    "Password": "#{SMTP_PASSWORD}#"
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": "#{OTLP_ENDPOINT}#"
    }
  }
}
