# Exemplo de variáveis de ambiente para os scripts da fábrica (tracker).
# Copie para `.env` (na raiz) e preencha. O `.env` é gitignored — NUNCA comite segredos.
# Os scripts scripts/import-tracker-issue.ps1 e scripts/push-tracker-tasks.ps1 carregam este .env
# automaticamente (via scripts/load-dotenv.ps1). O ambiente real tem prioridade sobre o .env.

# Azure DevOps — Personal Access Token, escopo Work Items (Read, e Read & Write para /sync-tasks).
AZDO_PAT=

# GitHub (se usar provider github e não tiver o gh autenticado) — token com escopo repo.
# GITHUB_TOKEN=

# GitLab (se usar provider gitlab) — token com escopo api.
# GITLAB_TOKEN=
