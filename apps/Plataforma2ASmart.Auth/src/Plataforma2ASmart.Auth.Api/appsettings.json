{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "#{DB_CONNECTION}#"
  },
  "Database": {
    "Provider": "SqlServer"
  },
  "Jwt": {
    "Issuer": "Plataforma2ASmart.Auth",
    "Audience": "Plataforma2ASmart.Auth",
    "Key": "#{JWT_SIGNING_KEY}#",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Smtp": {
    "Host": "#{SMTP_HOST}#",
    "Port": 587,
    "From": "#{SMTP_FROM}#",
    "Username": "#{SMTP_USERNAME}#",
    "Password": "#{SMTP_PASSWORD}#"
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": "#{OTLP_ENDPOINT}#"
    }
  },
  "Cors": {
    "AllowedOrigins": ["#{SPA_ORIGIN}#"]
  },
  "Auth": {
    "RefreshCookie": {
      "Name": "refresh_token",
      "Path": "/api/auth",
      "Secure": true,
      "SameSite": "None",
      "Days": 7
    }
  },
  "AllowedHosts": "*"
}
